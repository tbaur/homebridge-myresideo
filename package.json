{
  "name": "homebridge-myresideo",
  "displayName": "Homebridge My Resideo",
  "version": "1.2.0",
  "description": "A Homebridge plugin for Resideo (Honeywell Home) WiFi Water Leak & Freeze Detectors",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "homebridge-plugin",
    "resideo",
    "honeywell",
    "honeywell-home",
    "water-leak-detector",
    "leak-sensor",
    "freeze-detector",
    "homekit"
  ],
  "author": {
    "name": "tbaur",
    "url": "https://github.com/tbaur"
  },
  "maintainers": [
    {
      "name": "tbaur",
      "url": "https://github.com/tbaur"
    }
  ],
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/tbaur"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tbaur/homebridge-myresideo.git"
  },
  "bugs": {
    "url": "https://github.com/tbaur/homebridge-myresideo/issues"
  },
  "homepage": "https://github.com/tbaur/homebridge-myresideo#readme",
  "dependencies": {
    "@homebridge/plugin-ui-utils": "^2.2.4"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "homebridge": "^1.8.0",
    "jest": "^29.7.0",
    "nock": "^14.0.16",
    "ts-jest": "29.4.11",
    "typescript": "^5.7.2"
  },
  "engines": {
    "homebridge": "^1.6.0 || ^2.0.0",
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run clean && npm run build",
    "get-tokens": "node scripts/get-tokens.mjs",
    "test": "NODE_ENV=test jest --coverage",
    "test:watch": "NODE_ENV=test jest --watch",
    "test:unit": "NODE_ENV=test jest --coverage --testPathPattern=tests/unit",
    "test:integration": "NODE_ENV=test jest --testPathPattern=tests/integration --collectCoverage=false",
    "lint": "eslint . --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern coverage",
    "lint:fix": "eslint . --fix --ignore-pattern node_modules --ignore-pattern dist --ignore-pattern coverage"
  },
  "files": [
    "dist/**/*",
    "homebridge-ui",
    "config.schema.json",
    "LICENSE",
    "NOTICE",
    "README.md"
  ]
}
