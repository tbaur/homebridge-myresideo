{
  "pluginAlias": "MyResideo",
  "pluginType": "platform",
  "singular": true,
  "customUi": true,
  "customUiPath": "./homebridge-ui",
  "headerDisplay": "Homebridge plugin for Resideo / Honeywell Home WiFi Water Leak & Freeze Detectors. Use the **Link your Resideo account** panel above to sign in and populate your credentials.",
  "footerDisplay": "For help, see the [README](https://github.com/tbaur/homebridge-myresideo#readme).",
  "schema": {
    "type": "object",
    "properties": {
      "name": {
        "title": "Name",
        "type": "string",
        "default": "MyResideo",
        "description": "Plugin instance name shown in the Homebridge log."
      },
      "credentials": {
        "type": "object",
        "description": "OAuth2 credentials and tokens. Managed by the 'Link your Resideo account' panel above; not shown in this form.",
        "properties": {
          "consumerKey": {
            "title": "Consumer Key (API Key)",
            "type": "string"
          },
          "consumerSecret": {
            "title": "Consumer Secret (API Secret)",
            "type": "string"
          },
          "accessToken": {
            "title": "Access Token",
            "type": "string"
          },
          "refreshToken": {
            "title": "Refresh Token",
            "type": "string"
          }
        }
      },
      "options": {
        "type": "object",
        "properties": {
          "refreshRate": {
            "title": "Refresh Rate (seconds)",
            "type": "integer",
            "default": 120,
            "minimum": 30,
            "description": "How often to poll Resideo for device status. Minimum 30 seconds."
          },
          "freezeThresholdCelsius": {
            "title": "Default Freeze Threshold (°C)",
            "type": "number",
            "placeholder": 4,
            "description": "Optional. Temperature at or below which the optional freeze sensor trips. Leave blank to use each device's own configured low-temperature limit (falling back to 4 °C if the device reports none). A per-device override takes precedence."
          },
          "devices": {
            "type": "array",
            "title": "Per-Device Options",
            "items": {
              "type": "object",
              "properties": {
                "deviceID": {
                  "title": "Device ID",
                  "type": "string",
                  "required": true
                },
                "name": {
                  "title": "Display Name Override",
                  "type": "string"
                },
                "hideTemperatureSensor": {
                  "title": "Hide Temperature Sensor",
                  "type": "boolean",
                  "default": false
                },
                "hideHumiditySensor": {
                  "title": "Hide Humidity Sensor",
                  "type": "boolean",
                  "default": false
                },
                "enableFreezeSensor": {
                  "title": "Expose Freeze Sensor",
                  "type": "boolean",
                  "default": false,
                  "description": "Adds a contact sensor that trips when temperature is at or below the freeze threshold."
                },
                "freezeThresholdCelsius": {
                  "title": "Freeze Threshold Override (°C)",
                  "type": "number"
                }
              }
            }
          }
        }
      }
    }
  },
  "layout": [
    {
      "type": "fieldset",
      "title": "General",
      "expandable": false,
      "items": [
        "name",
        "options.refreshRate",
        "options.freezeThresholdCelsius"
      ]
    },
    {
      "type": "fieldset",
      "title": "Per-Device Options",
      "description": "Optional per-detector overrides. Leave this empty to apply the settings above to every detector.",
      "expandable": true,
      "expanded": false,
      "items": [
        {
          "key": "options.devices",
          "type": "tabarray",
          "title": "{{ value.name || value.deviceID || 'New device override' }}",
          "items": [
            "options.devices[].deviceID",
            "options.devices[].name",
            "options.devices[].hideTemperatureSensor",
            "options.devices[].hideHumiditySensor",
            "options.devices[].enableFreezeSensor",
            "options.devices[].freezeThresholdCelsius"
          ]
        }
      ]
    }
  ]
}
